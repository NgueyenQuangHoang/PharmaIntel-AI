# =============================================================================
# .env.example - mau cau hinh cho docker-compose.
# Sao chep file nay sang `.env` va dien gia tri thuc. KHONG commit `.env`.
# =============================================================================

# --- SQL Server ---
# Password phai strong: >= 8 ky tu, gom chu hoa, chu thuong, so, ky tu dac biet.
SA_PASSWORD=ChangeMe!Strong#2026
DB_PORT=1433

# --- Backend API ---
# Sinh ngau nhien >= 32 ky tu. Vi du PowerShell:
#   [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
JWT_KEY=replace-with-random-32+character-secret-string

# Gemini API key tu https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

ASPNETCORE_ENVIRONMENT=Production
API_PORT=5292
SEED_ON_STARTUP=false

# --- Frontend ---
WEB_PORT=5173
# URL ma BROWSER goi (khong phai mang noi bo cua compose).
# Mac dinh dung api da expose ra host.
VITE_API_URL=http://localhost:5292/api

# --- CORS ---
# Danh sach origin (CSV) duoc phep goi API. Trung khop chinh xac scheme + host + port.
# Vi du nhieu domain: WEB_ORIGINS=http://localhost:5173,https://app.pharmaintel.example.com
WEB_ORIGINS=http://localhost:5173,http://localhost:3000
